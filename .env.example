# Copy this file to .env and fill in your values.
# Secrets and environment-specific values only.
# Non-sensitive config (instructions, questions) lives in core/config.yaml.

# Required
OPENAI_API_KEY=sk-...

# Optional overrides
OPENAI_MODEL=gpt-4o
VECTOR_STORE_ID=vs_xxxxxxxxxxxxxxxxxxxxxxxxxx
DATA_DIR=data
CONFIG_PATH=core/config.yaml

# API key auth — leave empty to disable (open access for development)
API_KEY=
